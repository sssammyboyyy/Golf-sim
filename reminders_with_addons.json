        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"The Mulligan <bookings@themulligan.org>\",\n  \"to\": [\"{{ $json.guest_email }}\"],\n  \"subject\": \"\u26f3 See You Tomorrow! | Your Booking Reminder\",\n  \"html\": \"<div style=\\\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 580px; margin: 0 auto; color: #1f2937; background: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;\\\">\\n    <div style=\\\"background: linear-gradient(135deg, #166534 0%, #22c55e 100%); padding: 28px; text-align: center;\\\">\\n        <h1 style=\\\"color: white; margin: 0; font-size: 26px;\\\">\u26f3 See You Tomorrow!</h1>\\n        <p style=\\\"color: rgba(255,255,255,0.9); margin: 8px 0 0; font-size: 15px;\\\">Your tee time is confirmed</p>\\n    </div>\\n\\n    <div style=\\\"padding: 25px;\\\">\\n        <p style=\\\"font-size: 16px; margin: 0 0 15px;\\\">Hi <strong>{{ $json.guest_name }}</strong>,</p>\\n        <p style=\\\"color: #6b7280; line-height: 1.6; margin: 0 0 20px;\\\">We're excited to have you at The Mulligan! Here's everything you need to know.</p>\\n        \\n        <div style=\\\"background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); border: 2px solid #22c55e; border-radius: 12px; padding: 20px; margin: 0 0 25px; text-align: center;\\\">\\n            <p style=\\\"margin: 0 0 8px; font-size: 22px; font-weight: bold; color: #166534;\\\">\ud83d\udcc5 {{ $json.booking_date }}</p>\\n            <p style=\\\"margin: 0 0 8px; font-size: 20px; color: #166534;\\\">\ud83d\udd50 {{ $json.start_time }}</p>\\n            <p style=\\\"margin: 0; font-size: 15px; color: #6b7280;\\\">\ud83d\udccd Simulator {{ $json.simulator_id }}</p>\\n        </div>\\n\\n        {{ ($json.addon_coaching || $json.addon_club_rental) ? `<div style=\"background:#f0fdf4;border:1px solid #d1fae5;border-radius:10px;padding:15px;margin:15px 0;\"><p style=\"margin:0 0 8px;font-weight:bold;color:#065f46;font-size:13px;\">\u2705 YOUR ADD-ONS</p><ul style=\"margin:0;padding-left:18px;color:#6b7280;font-size:14px;line-height:2;\">` + ($json.addon_coaching ? `<li>Coaching Session</li>` : '') + ($json.addon_club_rental ? `<li>Club Hire</li>` : '') + `</ul></div>` : '' }}<div style=\\\"background: #fffbeb; border: 1px solid #f59e0b; border-radius: 12px; padding: 20px; margin: 0 0 20px;\\\">\\n            <p style=\\\"margin: 0 0 15px; font-weight: bold; color: #b45309; font-size: 15px; text-align: center;\\\">\ud83d\udccb THE MULLIGAN'S BASICS</p>\\n            <ul style=\\\"margin: 0; padding-left: 20px; color: #4b5563; font-size: 14px; line-height: 1.9;\\\">\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>Arrive 15 mins early</strong> for smooth check-in</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>Bring your own clubs</strong> or rent with us</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>No spiked shoes, high heels</strong> \u2013 flat soles only</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>Golf glove is compulsory</strong> (available for purchase)</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>Clean balls & undamaged clubs only</strong> \u2013 protects our screens</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>\ud83d\udeab No Sharpie-marked balls</strong> \u2013 they permanently damage screens!</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>Under 12s</strong> must be accompanied by an adult</li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>Keep food & drinks off the turf</strong></li>\\n                <li style=\\\"margin-bottom: 8px;\\\"><strong>No smoking/vaping indoors</strong></li>\\n            </ul>\\n            <p style=\\\"margin: 15px 0 0; padding-top: 12px; border-top: 1px solid #fcd34d; font-size: 12px; color: #92400e; text-align: center;\\\">\u26a0\ufe0f Staff reserves the right to stop play if rules aren't followed</p>\\n        </div>\\n\\n        <div style=\\\"text-align: center; margin: 0 0 20px;\\\">\\n            <a href=\\\"https://maps.google.com/?q=38A+Chopin+St+Vanderbijlpark\\\" style=\\\"display: inline-block; background: #166534; color: white; padding: 12px 28px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px;\\\">\ud83d\udccd Get Directions</a>\\n        </div>\\n\\n        <p style=\\\"color: #6b7280; margin: 0; text-align: center;\\\">See you on the tee! \ud83c\udfcc\ufe0f</p>\\n    </div>\\n    \\n    <div style=\\\"text-align: center; padding: 18px; background: #166534; color: rgba(255,255,255,0.9); font-size: 12px;\\\">\\n        38A Chopin St, Vanderbijlpark S.W. 5 | The Simulator Never Judges! \u26f3\\n    </div>\\n</div>\"\n}",
