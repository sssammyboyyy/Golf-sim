        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"The Mulligan <bookings@themulligan.org>\",\n  \"to\": [\"{{ $json.guest_email }}\"],\n  \"subject\": \"\u26f3 Tee Time in 1 Hour! | The Mulligan\",\n  \"html\": \"<div style=\\\"font-family: 'Segoe UI', Arial, sans-serif; color: #1f2937; max-width: 520px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb;\\\">\\n    <div style=\\\"background: linear-gradient(135deg, #166534 0%, #22c55e 100%); padding: 25px; text-align: center;\\\">\\n        <h1 style=\\\"color: white; margin: 0; font-size: 24px;\\\">\u26f3 You're Up Next!</h1>\\n        <p style=\\\"color: rgba(255,255,255,0.9); margin: 8px 0 0; font-size: 15px;\\\">Your session starts in 1 hour</p>\\n    </div>\\n    <div style=\\\"padding: 25px;\\\">\\n        <p style=\\\"font-size: 16px; margin: 0 0 15px;\\\">Hi <strong>{{ $json.guest_name }}</strong>,</p>\\n        <p style=\\\"color: #6b7280; line-height: 1.6; margin: 0 0 20px;\\\">Get ready to tee off! We're prepping your bay and can't wait to see you.</p>\\n        <div style=\\\"background: #f0fdf4; border-left: 4px solid #22c55e; padding: 18px; border-radius: 8px; margin: 0 0 20px;\\\">\\n            <p style=\\\"margin: 0 0 8px; font-size: 26px; font-weight: bold; color: #166534;\\\">\ud83d\udd50 {{ $json.start_time }}</p>\\n            <p style=\\\"margin: 0; font-size: 16px; color: #6b7280;\\\">\ud83d\udccd Simulator {{ $json.simulator_id }}</p>\\n        </div>\\n        {{ ($json.addon_coaching || $json.addon_club_rental) ? `<div style=\"background:#f0fdf4;border:1px solid #d1fae5;border-radius:10px;padding:15px;margin:15px 0;\"><p style=\"margin:0 0 8px;font-weight:bold;color:#065f46;font-size:13px;\">\u2705 YOUR ADD-ONS</p><ul style=\"margin:0;padding-left:18px;color:#6b7280;font-size:14px;line-height:2;\">` + ($json.addon_coaching ? `<li>Coaching Session</li>` : '') + ($json.addon_club_rental ? `<li>Club Hire</li>` : '') + `</ul></div>` : '' }}<div style=\\\"background: #fffbeb; border: 1px solid #fcd34d; border-radius: 10px; padding: 18px; margin: 0 0 20px;\\\">\\n            <p style=\\\"margin: 0 0 12px; font-weight: bold; color: #b45309; font-size: 14px;\\\">\ud83d\udccb QUICK HOUSE RULES</p>\\n            <ul style=\\\"margin: 0; padding-left: 18px; color: #6b7280; line-height: 1.9; font-size: 14px;\\\">\\n                <li><strong>Arrive 15 mins early</strong> \u2013 check in & warm up</li>\\n                <li><strong>Flat-soled shoes only</strong> \u2013 no heels or cleats</li>\\n                <li><strong>Food & drinks welcome</strong> \u2013 just no red wine!</li>\\n                <li><strong>Be gentle with the clubs</strong> \u2013 treat them like your own</li>\\n            </ul>\\n        </div>\\n        <p style=\\\"color: #dc2626; font-weight: bold; font-size: 14px; margin: 0 0 15px;\\\">\u26a0\ufe0f Running late? Just give us a call!</p>\\n        <p style=\\\"color: #6b7280; margin: 0;\\\">See you soon! \ud83c\udfcc\ufe0f</p>\\n    </div>\\n    <div style=\\\"text-align: center; padding: 18px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 12px; color: #9ca3af;\\\">The Mulligan | Vanderbijlpark</div>\\n</div>\"\n}",
